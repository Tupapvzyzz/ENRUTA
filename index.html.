<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ENRUTA</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>

<div class="phone">

  <!-- PORTADA -->
  <section class="screen splash active" id="splash">
    <div class="status">9:41 <span>▰ WiFi 🔋</span></div>
    <div class="splash-content">
      <h1>EN<span>RUTA</span></h1>
      <p>Entregas en moto,<br>más rápidas y <b>a tu precio.</b></p>
      <div class="loader"><i></i></div>
      <small>Cargando...</small>
    </div>
  </section>

  <!-- SELECCION -->
  <section class="screen" id="selectRole">
    <div class="status">9:41 <span>▰ WiFi 🔋</span></div>
    <div class="brand">EN<span>RUTA</span></div>
    <h2>¿Cómo quieres continuar?</h2>
    <p class="sub">Selecciona el tipo de cuenta que deseas usar</p>

    <button class="role-card" onclick="chooseRole('usuario')">
      <div class="icon">👤</div>
      <div><b>Soy usuario</b><small>Quiero solicitar entregas</small></div>
    </button>

    <button class="role-card" onclick="chooseRole('repartidor')">
      <div class="icon">🏍️</div>
      <div><b>Soy repartidor</b><small>Quiero hacer entregas</small></div>
    </button>

    <p class="login-text">¿Ya tienes cuenta? <span onclick="go('login')">Iniciar sesión</span></p>
  </section>

  <!-- REGISTRO USUARIO -->
  <section class="screen" id="registerUser">
    <div class="top"><button onclick="go('selectRole')">‹</button><h3>Registro de usuario</h3></div>
    <form onsubmit="saveUser(event)">
      <label>Nombre completo</label>
      <input id="uName" required placeholder="Ej. Anthony Jara">
      <label>Correo electrónico</label>
      <input id="uEmail" type="email" required placeholder="correo@gmail.com">
      <label>Número de celular</label>
      <input id="uPhone" required placeholder="987 654 321">
      <label>Contraseña</label>
      <input id="uPass" type="password" required placeholder="••••••••">
      <button class="btn">Registrarme</button>
    </form>
    <p class="login-text">¿Ya tienes cuenta? <span onclick="go('login')">Iniciar sesión</span></p>
  </section>

  <!-- REGISTRO REPARTIDOR 1 -->
  <section class="screen" id="driver1">
    <div class="top"><button onclick="go('selectRole')">‹</button><h3>Registro de repartidor</h3></div>
    <p class="step">Paso 1 de 4</p><div class="progress"><i style="width:25%"></i></div>
    <label>Nombre completo</label><input id="dName" required placeholder="Ej. Carlos Gómez">
    <label>Correo electrónico</label><input id="dEmail" type="email" required placeholder="correo@gmail.com">
    <label>Número de celular</label><input id="dPhone" required placeholder="912 345 678">
    <label>Contraseña</label><input id="dPass" type="password" required placeholder="••••••••">
    <button class="btn" onclick="go('driver2')">Continuar</button>
  </section>

  <!-- REGISTRO REPARTIDOR 2 -->
  <section class="screen" id="driver2">
    <div class="top"><button onclick="go('driver1')">‹</button><h3>Registro de repartidor</h3></div>
    <p class="step">Paso 2 de 4</p><div class="progress"><i style="width:50%"></i></div>
    <h3>Documentos personales</h3>
    <label class="upload">📄 DNI <input id="dni" type="file" accept="image/*,.pdf" onchange="uploaded(this)"><span>Subir foto</span></label>
    <label class="upload">🪪 Licencia de conducir <input id="licencia" type="file" accept="image/*,.pdf" onchange="uploaded(this)"><span>Subir foto</span></label>
    <label class="upload">🛡️ SOAT vigente <input id="soat" type="file" accept="image/*,.pdf" onchange="uploaded(this)"><span>Subir foto</span></label>
    <button class="btn" onclick="go('driver3')">Continuar</button>
  </section>

  <!-- REGISTRO REPARTIDOR 3 -->
  <section class="screen" id="driver3">
    <div class="top"><button onclick="go('driver2')">‹</button><h3>Registro de repartidor</h3></div>
    <p class="step">Paso 3 de 4</p><div class="progress"><i style="width:75%"></i></div>
    <h3>Información de la moto</h3>
    <label>Marca y modelo</label><input id="motoModel" placeholder="Honda XR190L">
    <label>Año</label><input id="motoYear" placeholder="2022">
    <label>Placa</label><input id="motoPlate" placeholder="ABC-123">
    <label class="upload photo">📷 Foto de la moto <input id="motoPhoto" type="file" accept="image/*" onchange="uploaded(this)"><span>Subir foto</span></label>
    <button class="btn" onclick="go('driver4')">Continuar</button>
  </section>

  <!-- REGISTRO REPARTIDOR 4 -->
  <section class="screen" id="driver4">
    <div class="top"><button onclick="go('driver3')">‹</button><h3>Registro de repartidor</h3></div>
    <p class="step">Paso 4 de 4</p><div class="progress"><i style="width:100%"></i></div>
    <div class="success">✓</div>
    <h2>Verificación en proceso</h2>
    <p class="sub">Revisaremos tus documentos. Tiempo estimado: 24 a 48 horas.</p>
    <button class="btn" onclick="saveDriver()">Enviar registro</button>
  </section>

  <!-- LOGIN -->
  <section class="screen" id="login">
    <div class="brand">EN<span>RUTA</span></div>
    <h2>Iniciar sesión</h2>
    <div class="switch">
      <button class="active" onclick="loginRole='usuario';setSwitch(this)">Usuario</button>
      <button onclick="loginRole='repartidor';setSwitch(this)">Repartidor</button>
    </div>
    <label>Correo o celular</label><input id="loginUser" placeholder="correo o celular">
    <label>Contraseña</label><input id="loginPass" type="password" placeholder="••••••••">
    <button class="btn" onclick="login()">Iniciar sesión</button>
    <p class="login-text">¿No tienes cuenta? <span onclick="go('selectRole')">Regístrate</span></p>
  </section>

  <!-- HOME USUARIO -->
  <section class="screen appscreen" id="userHome">
    <div class="header"><div class="brand smallbrand">EN<span>RUTA</span></div><span>🔔</span></div>
    <h2>Publica tu ruta</h2>
    <input id="pickup" placeholder="Punto de recojo">
    <input id="dropoff" placeholder="Punto de entrega">
    <textarea id="packageDesc" placeholder="Describe el paquete"></textarea>
    <input id="price" type="number" placeholder="Precio propuesto S/">
    <button class="btn" onclick="publishRoute()">Rutear</button>

    <h3>Mis rutas publicadas</h3>
    <div id="myRoutes"></div>
    <nav><button class="active">Publicar</button><button onclick="go('profile')">Perfil</button></nav>
  </section>

  <!-- OFERTAS USUARIO -->
  <section class="screen appscreen" id="offers">
    <div class="top"><button onclick="go('userHome')">‹</button><h3>Ofertas recibidas</h3></div>
    <div id="offersList"></div>
  </section>

  <!-- HOME REPARTIDOR -->
  <section class="screen appscreen" id="driverHome">
    <div class="header"><div class="brand smallbrand">EN<span>RUTA</span></div><span>🔔</span></div>
    <h2>Rutas disponibles</h2>
    <p class="sub">Elige la ruta que más te convenga</p>
    <div class="tabs"><button class="active">Todas</button><button>Cercanas</button><button>Nuevas</button></div>
    <div id="routesList"></div>
    <nav><button class="active">Rutas</button><button onclick="go('myOffers')">Mis ofertas</button><button onclick="go('profile')">Perfil</button></nav>
  </section>

  <!-- DETALLE RUTA -->
  <section class="screen appscreen" id="routeDetail">
    <div class="top"><button onclick="go('driverHome')">‹</button><h3>Detalle de la ruta</h3></div>
    <div class="map"><i></i><b></b><em></em></div>
    <div id="routeDetailContent"></div>
  </section>

  <!-- HACER OFERTA -->
  <section class="screen appscreen" id="makeOffer">
    <div class="top"><button onclick="go('routeDetail')">‹</button><h3>Hacer oferta</h3></div>
    <div class="card center"><small>Tu oferta</small><h1 id="suggestedPrice">S/ 0.00</h1></div>
    <label>Tu oferta (S/)</label><input id="offerPrice" type="number" placeholder="11.50">
    <label>Mensaje opcional</label><textarea id="offerMsg" placeholder="Puedo recogerlo en 5 minutos."></textarea>
    <button class="btn" onclick="sendOffer()">Enviar oferta</button>
  </section>

  <!-- MIS OFERTAS -->
  <section class="screen appscreen" id="myOffers">
    <div class="top"><button onclick="go('driverHome')">‹</button><h3>Mis ofertas</h3></div>
    <div id="myOffersList"></div>
  </section>

  <!-- RUTA EN CURSO -->
  <section class="screen appscreen" id="currentRoute">
    <div class="top"><button onclick="go(currentRole==='usuario'?'userHome':'driverHome')">‹</button><h3>Mi ruta en curso</h3></div>
    <div class="card">
      <h3 id="currentDriver">Carlos Gómez ⭐ 4.9</h3>
      <p class="sub">Motero verificado · Honda XR190L</p>
      <button class="outline">Chat</button><button class="outline">Llamar</button>
    </div>
    <div class="card timeline">
      <p>✅ Solicitud ruteada</p>
      <p>✅ Motero aceptó tu ruta</p>
      <p>✅ En camino al punto de recojo</p>
      <p>✅ Paquete recogido</p>
      <p>🟢 En camino al destino</p>
      <p>⚪ Entregado</p>
    </div>
    <button class="danger" onclick="cancelRoute()">Cancelar ruta</button>
  </section>

  <!-- PERFIL -->
  <section class="screen appscreen" id="profile">
    <div class="top"><button onclick="go(currentRole==='repartidor'?'driverHome':'userHome')">‹</button><h3>Perfil</h3></div>
    <div class="card center">
      <div class="avatar">👤</div>
      <h2 id="profileName">Anthony Jara</h2>
      <p id="profileInfo" class="sub">usuario@enruta.com</p>
    </div>
    <div class="card menu">
      <p>👤 Información personal ›</p>
      <p>💳 Métodos de pago ›</p>
      <p>📍 Direcciones guardadas ›</p>
      <p>❓ Centro de ayuda ›</p>
      <p class="red" onclick="go('selectRole')">🚪 Cerrar sesión</p>
    </div>
  </section>

</div>

<script src="enruta.js"></script>
</body>
</html>
